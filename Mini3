-- Câu 1: Trigger chuẩn hóa điểm số (0 - 10)
DELIMITER //
CREATE TRIGGER tg_check_score
BEFORE INSERT ON grades
FOR EACH ROW
BEGIN
    IF NEW.score < 0 THEN 
        SET NEW.score = 0;
    ELSEIF NEW.score > 10 THEN 
        SET NEW.score = 10;
    END IF;
END //
DELIMITER ;

-- Câu 2: Transaction thêm sinh viên mới an toàn
