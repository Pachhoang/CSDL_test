-- =============================================================

-- Câu 3: Trigger ghi nhật ký thay đổi điểm
DELIMITER //
CREATE TRIGGER tg_log_grade_update
AFTER UPDATE ON grades
FOR EACH ROW
BEGIN
    -- Chỉ ghi log nếu điểm số thực sự bị thay đổi
    IF OLD.score <> NEW.score THEN
        INSERT INTO grade_log (student_id, old_score, new_score, change_date)
        VALUES (OLD.student_id, OLD.score, NEW.score, NOW());
    END IF;
END //
DELIMITER ;

-- Câu 4: Procedure đóng học phí có kiểm tra nợ âm
DELIMITER //
CREATE PROCEDURE sp_pay_tuition()
BEGIN
    DECLARE v_debt DECIMAL(10,2);
    
    START TRANSACTION;
    
    -- Thực hiện trừ nợ
    UPDATE students 
    SET total_debt = total_debt - 2000000 
    WHERE student_id = 'SV01';
    
    -- Kiểm tra số dư nợ sau khi trừ
    SELECT total_debt INTO v_debt FROM students WHERE student_id = 'SV01';
    
    IF v_debt < 0 THEN
        -- Nếu nợ âm thì hủy giao dịch
        ROLLBACK;
    ELSE
        -- Nếu hợp lệ thì xác nhận
        COMMIT;
    END IF;
END //
DELIMITER ;
