-- Câu 2: UPDATE & DELETE
-- Tăng lương 15% cho Forward có rating trung bình > 8.0
UPDATE players 
SET salary = salary * 1.15 
WHERE position = 'Forward' 
AND player_id IN (
    SELECT player_id FROM player_statistics 
    GROUP BY player_id HAVING AVG(rating_score) > 8.0
);

-- Xóa thống kê có thẻ vàng > 2
DELETE FROM player_statistics WHERE yellow_cards > 2;

-- =============================================================
-- PHẦN 3 & 4: QUERIES (TRUY VẤN)
-- =============================================================

-- Câu 3.1: Lương > 50tr hoặc Midfielder
SELECT full_name, jersey_number, position FROM players 
WHERE salary > 50000000 OR position = 'Midfielder';

-- Câu 4.1: Chi tiết bàn thắng, kiến tạo theo đội
SELECT p.full_name, t.team_name, SUM(ps.goals) as total_goals, SUM(ps.assists) as total_assists
FROM players p
JOIN teams t ON p.team_id = t.team_id
LEFT JOIN player_statistics ps ON p.player_id = ps.player_id
GROUP BY p.player_id, t.team_name;

-- Câu 4.3: Cầu thủ lương cao nhất
SELECT player_id, full_name, salary FROM players 
WHERE salary = (SELECT MAX(salary) FROM players);

-- =============================================================
-- PHẦN 5: INDEX & VIEW
-- =============================================================

CREATE INDEX idx_pos_salary ON players(position, salary);

CREATE VIEW vw_TeamSummary AS
SELECT t.team_name, COUNT(p.player_id) as total_players, SUM(p.salary) as total_salary_fund
FROM teams t
JOIN players p ON t.team_id = p.team_id
WHERE p.salary > 0
GROUP BY t.team_name;

-- =============================================================
-- PHẦN 6: TRIGGER
-- =============================================================

-- Trigger 1: Ghi nhiều bàn thắng (>10) thì tăng lương
DELIMITER //
CREATE TRIGGER trg_increase_salary_on_goals
AFTER INSERT ON player_statistics
FOR EACH ROW
BEGIN
    IF NEW.goals > 10 THEN
        UPDATE players SET salary = salary * 1.05 WHERE player_id = NEW.player_id;
    END IF;
END //

-- Trigger 2: Trận đấu kết thúc thì tăng hạng đội thắng (Ví dụ cho Home Team)
CREATE TRIGGER trg_update_ranking_finished
AFTER UPDATE ON matches
FOR EACH ROW
BEGIN
    IF NEW.match_status = 'Finished' AND OLD.match_status <> 'Finished' THEN
        UPDATE teams SET ranking_position = ranking_position + 1 WHERE team_id = NEW.home_team_id;
    END IF;
END //
DELIMITER ;

-- =============================================================
-- PHẦN 7: STORED PROCEDURE
-- =============================================================

-- SP 1: Phân loại cầu thủ theo bàn thắng
DELIMITER //
CREATE PROCEDURE sp_ClassifyPlayer(IN p_id INT)
BEGIN
    DECLARE g_count INT;
    SELECT SUM(goals) INTO g_count FROM player_statistics WHERE player_id = p_id;
    IF g_count > 20 THEN SELECT 'Excellent';
    ELSEIF g_count >= 10 THEN SELECT 'Good';
    ELSE SELECT 'Average';
    END IF;
END //

-- SP 2: Chuyển nhượng cầu thủ (Transaction)
CREATE TABLE transfer_history (
    id INT PRIMARY KEY AUTO_INCREMENT,
    player_id INT,
    from_team INT,
    to_team INT,
    transfer_date DATETIME DEFAULT CURRENT_TIMESTAMP
);

CREATE PROCEDURE sp_TransferPlayer(IN p_id INT, IN new_team INT)
BEGIN
    DECLARE old_team INT;
    DECLARE EXIT HANDLER FOR SQLEXCEPTION BEGIN ROLLBACK; END;
    START TRANSACTION;
        SELECT team_id INTO old_team FROM players WHERE player_id = p_id;
        UPDATE players SET team_id = new_team WHERE player_id = p_id;
        INSERT INTO transfer_history(player_id, from_team, to_team) VALUES (p_id, old_team, new_team);
    COMMIT;
END //
DELIMITER ;
