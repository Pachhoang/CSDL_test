CREATE DATABASE kiemtrachatluong;
USE kiemtrachatluong;

CREATE TABLE Books(
    book_id VARCHAR(5) PRIMARY KEY,
    title VARCHAR(150) UNIQUE NOT NULL,
    author VARCHAR(100) NOT NULL,
    category VARCHAR(50) NOT NULL,
    price DECIMAL(10,2) NOT NULL,
    status ENUM('Available', 'Borrowed', 'Lost') DEFAULT('Available'),
    published_year INT NOT NULL
);

CREATE TABLE Members(
    member_id VARCHAR(5) PRIMARY KEY,
    full_name VARCHAR(100) NOT NULL,
    email VARCHAR(100) UNIQUE NOT NULL,
    phone VARCHAR(15) NOT NULL,
    membership_type ENUM('Student', 'Teacher', 'Guest')
);

CREATE TABLE Loans(
    loan_id INT PRIMARY KEY AUTO_INCREMENT,
    book_id VARCHAR(5),
    member_id VARCHAR(5),
    loan_date DATE NOT NULL,
    return_date DATE,
    FOREIGN KEY (book_id) REFERENCES Books(book_id),
    FOREIGN KEY (member_id) REFERENCES Members(member_id)
);

CREATE TABLE Fines(
    fine_id INT PRIMARY KEY AUTO_INCREMENT,
    loan_id INT,
    fine_amount DECIMAL(10,2) NOT NULL,
    fine_reason VARCHAR(255),
    FOREIGN KEY (loan_id) REFERENCES Loans(loan_id)
);

