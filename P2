-- ==========================================
-- PHẦN 4: TRUY VẤN NÂNG CAO (JOIN & GROUP BY)
-- ==========================================

-- 1. Thông tin mượn sách của độc giả loại 'Student'
SELECT l.loan_id, m.full_name, b.title, l.loan_date
FROM Loans l
JOIN Members m ON l.member_id = m.member_id
JOIN Books b ON l.book_id = b.book_id
WHERE m.membership_type = 'Student';

-- 2. Thống kê mỗi thể loại có bao nhiêu cuốn sách
SELECT category, COUNT(*) AS total_books
FROM Books
GROUP BY category;

-- 3. Liệt kê độc giả và tổng số lần mượn (kể cả người chưa mượn)
SELECT m.full_name, COUNT(l.loan_id) AS total_loans
FROM Members m
LEFT JOIN Loans l ON m.member_id = l.member_id
GROUP BY m.member_id, m.full_name;

-- 4. Tìm các cuốn sách chưa từng được mượn
SELECT * FROM Books
WHERE book_id NOT IN (SELECT DISTINCT book_id FROM Loans);

-- 5. Tính tổng số tiền phạt mỗi độc giả (full_name, total_fine)
SELECT m.full_name, SUM(f.fine_amount) AS total_fine
FROM Members m
JOIN Loans l ON m.member_id = l.member_id
JOIN Fines f ON l.loan_id = f.loan_id
GROUP BY m.member_id, m.full_name;

-- 6. Độc giả đã mượn trên 2 cuốn sách khác nhau
SELECT m.full_name
FROM Members m
JOIN Loans l ON m.member_id = l.member_id
GROUP BY m.member_id, m.full_name
HAVING COUNT(DISTINCT l.book_id) > 2;

-- 7. Độc giả mượn cuốn sách có giá cao nhất
SELECT m.full_name, b.title, b.price
FROM Loans l
JOIN Members m ON l.member_id = m.member_id
JOIN Books b ON l.book_id = b.book_id
WHERE b.price = (SELECT MAX(price) FROM Books);

-- 8. Thông tin sách 'Tiểu thuyết' đã được mượn ít nhất một lần
SELECT DISTINCT b.*
FROM Books b
JOIN Loans l ON b.book_id = l.book_id
WHERE b.category = 'Tiểu thuyết';
