SET phone = '0999999999' 
WHERE user_id = 'U03';

-- 5. Xóa các bản ghi 'Returned' trước ngày 2025-10-03
DELETE FROM Borrows 
WHERE status = 'Returned' AND borrow_date < '2025-10-03';


-- PHẦN 2: TRUY VẤN CƠ BẢN
-- 6. Sách có giá từ 100k - 250k và còn hàng
SELECT book_id, title, price 
FROM Book 
WHERE price BETWEEN 100000 AND 250000 AND stock > 0;

-- 7. Người dùng họ Nguyễn
SELECT full_name, email 
FROM Users 
WHERE full_name LIKE 'Nguyễn %';

-- 8. Danh sách mượn sắp xếp theo ngày giảm dần
SELECT borrow_id, user_id, borrow_date 
FROM Borrows 
ORDER BY borrow_date DESC;

-- 9. Top 3 sách đắt nhất
SELECT * FROM Book 
ORDER BY price DESC 
LIMIT 3;

-- 10. Phân trang: Bỏ 2, lấy 2 sách tiếp theo
SELECT title, stock 
FROM Book 
LIMIT 2 OFFSET 2;


-- PHẦN 3: TRUY VẤN NÂNG CAO
-- 11. Phiếu đang mượn (Borrowing) kèm tên user và tên sách
SELECT b.borrow_id, u.full_name, bk.title, b.borrow_date
FROM Borrows b
JOIN Users u ON b.user_id = u.user_id
JOIN Book bk ON b.book_id = bk.book_id
WHERE b.status = 'Borrowing';

-- 12. Tất cả danh mục và sách thuộc danh mục đó (bao gồm danh mục trống)
SELECT c.category_name, b.title
FROM Categories c
LEFT JOIN Book b ON c.category_id = b.category_id;

-- 13. Tổng số lượt mượn theo từng trạng thái
SELECT status, COUNT(*) AS Total_Borrows
FROM Borrows
GROUP BY status;

-- 14. Người dùng có từ 2 lượt mượn trở lên
SELECT u.full_name, COUNT(b.borrow_id) AS Borrow_Count
FROM Users u
JOIN Borrows b ON u.user_id = b.user_id
GROUP BY u.user_id, u.full_name
HAVING COUNT(b.borrow_id) >= 2;

-- 15. Sách có giá thấp hơn giá trung bình
SELECT book_id, title, price 
FROM Book 
WHERE price < (SELECT AVG(price) FROM Book);

-- 16. Người dùng từng mượn sách 'Clean Code'
SELECT DISTINCT u.full_name, u.phone
FROM Users u
JOIN Borrows br ON u.user_id = br.user_id
JOIN Book bk ON br.book_id = bk.book_id
WHERE bk.title = 'Clean Code';
