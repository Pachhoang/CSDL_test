-- PHẦN 1: CẬP NHẬT VÀ XÓA DỮ LIỆU
-- 3. Tăng stock thêm 10 và tăng price lên 5% cho sách 'Sapiens'
UPDATE Book 
SET stock = stock + 10, price = price * 1.05 
WHERE title = 'Sapiens';

-- 4. Cập nhật số điện thoại user U03
